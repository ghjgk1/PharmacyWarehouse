<Window x:Class="PharmacyWarehouse.Windows.InventoryEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Инвентаризация" 
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="{StaticResource BackgroundDarkBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="txtTitle" Style="{StaticResource H2}"/>
            <TextBlock x:Name="txtSubtitle" Style="{StaticResource BodyText}"/>
        </StackPanel>

        <!-- Search and Filters -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Vertical">
                <TextBox x:Name="txtSearch" 
                         ToolTip="Поиск по названию, серии, производителю..." 
                         Margin="0,0,0,8"
                         TextChanged="TxtSearch_TextChanged"/>
                
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="chkOnlyUnverified" 
                              Content="Только не проверенные" 
                              Margin="0,0,8,0"
                              Checked="Filters_Changed"
                              Unchecked="Filters_Changed"/>
                    <CheckBox x:Name="chkOnlyDifferences" 
                              Content="Только с расхождениями" 
                              Checked="Filters_Changed"
                              Unchecked="Filters_Changed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Progress Bar -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="txtProgress" Style="{StaticResource BodyText}"/>
                    <ProgressBar x:Name="progressBar" Height="10" Margin="0,4,0,0"/>
                </StackPanel>
                <TextBlock x:Name="txtCompleteHint" 
                           Grid.Column="1" 
                           Style="{StaticResource BodyText}" 
                           Foreground="Gray"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <DataGrid x:Name="dgLines" 
                  Grid.Row="3" 
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Margin="0,0,0,12"
                  RowHeight="40">
            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </DataGrid.Resources>
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" 
                                    Binding="{Binding Batch.Product.Name}" 
                                    IsReadOnly="True" 
                                    Width="*"/>
                <DataGridTextColumn Header="Производитель" 
                                    Binding="{Binding Batch.Product.Manufacturer}" 
                                    IsReadOnly="True" 
                                    Width="120"/>
                <DataGridTextColumn Header="Серия" 
                                    Binding="{Binding Batch.Series}" 
                                    IsReadOnly="True" 
                                    Width="80"/>
                <DataGridTextColumn Header="Срок годности" 
                                    Binding="{Binding Batch.ExpirationDate, StringFormat='dd.MM.yyyy'}" 
                                    IsReadOnly="True" 
                                    Width="100"/>
                <DataGridTextColumn Header="Учётный" 
                                    Binding="{Binding ExpectedQuantity}" 
                                    IsReadOnly="True" 
                                    Width="80"/>
                
                <!-- Actual Quantity + Quick Actions -->
                <DataGridTemplateColumn Header="Фактический" Width="320">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Кнопка -1 -->
                                <Button Grid.Column="0" 
                                        Content="-1" 
                                        Width="3" 
                                        Height="20"
                                        Padding="0"
                                        Margin="0"
                                        FontSize="10"
                                        Click="BtnMinus_Click"
                                        Tag="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource OutlineButton}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTracked}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <!-- Текстовое поле -->
                                <TextBox x:Name="txtActual" 
                                         Grid.Column="1"
                                         Margin="4,0"
                                         Padding="4"
                                         Text="{Binding ActualQuantity, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                         PreviewTextInput="TxtActual_PreviewTextInput"
                                         PreviewKeyDown="TxtActual_PreviewKeyDown"
                                         TextChanged="TxtActual_TextChanged"
                                         Width="60">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="IsReadOnly" Value="False"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTracked}" Value="True">
                                                    <Setter Property="IsReadOnly" Value="True"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <!-- Кнопка +1 -->
                                <Button Grid.Column="2" 
                                        Content="+1" 
                                        Width="10" 
                                        Height="20"
                                        Padding="0"
                                        Margin="0"
                                        FontSize="10"
                                        Click="BtnPlus_Click"
                                        Tag="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource OutlineButton}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTracked}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <!-- Кнопка сброса -->
                                <Button Grid.Column="3" 
                                        Content="0" 
                                        Width="10" 
                                        Height="20"
                                        Padding="0"
                                        Margin="10 0"
                                        FontSize="10"
                                        Click="BtnReset_Click"
                                        Tag="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTracked}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <!-- Difference with Color -->
                <DataGridTextColumn Header="Расхождение" 
                                    Binding="{Binding Difference}" 
                                    IsReadOnly="True" 
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DifferenceType}" Value="Shortage">
                                    <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DifferenceType}" Value="Surplus">
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DifferenceType}" Value="None">
                                    <Setter Property="Foreground" Value="Gray"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- MDLP Scan Button -->
                <DataGridTemplateColumn Header="МДЛП" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Сканировать" 
                                    Style="{StaticResource OutlineButton}"
                                    Click="BtnScan_Click"
                                    Tag="{Binding}"
                                    Margin="0"
                                    Visibility="{Binding IsTracked, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Экспорт в Excel" 
                    Style="{StaticResource OutlineButton}"
                    Click="Export_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"
                    Margin="0,0,8,0"/>
            <Button x:Name="btnComplete" 
                    Content="Завершить инвентаризацию"
                    Style="{StaticResource SuccessButton}"
                    Click="Complete_Click"
                    IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
