<Window x:Class="PharmacyWarehouse.Windows.MdlpScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сканирование МДЛП"
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundDarkBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Сканирование DataMatrix кодов" 
                   Style="{StaticResource H2}" 
                   Margin="0,0,0,12"/>

        <!-- Product Info -->
        <Border Grid.Row="1" 
                Style="{StaticResource Card}" 
                Padding="12" 
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="txtProductName" 
                           TextWrapping="Wrap" 
                           Style="{StaticResource BodyText}" 
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="txtProductDetails" 
                           TextWrapping="Wrap" 
                           Style="{StaticResource BodyTextSmall}" 
                           Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- Scan Area -->
        <Border Grid.Row="2" 
                Style="{StaticResource Card}" 
                Padding="12" 
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Сканируйте код" Style="{StaticResource BodyTextSmall}" Foreground="Gray"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtScan" 
                             Grid.Column="0"
                             PlaceholderText="Код DataMatrix..."
                             Style="{StaticResource TextBox}"
                             KeyDown="TxtScan_KeyDown"/>
                    <TextBlock x:Name="txtCount" 
                               Grid.Column="1"
                               Text="0" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center" 
                               Margin="12,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Scanned Codes List -->
        <Border Grid.Row="3" 
                Style="{StaticResource Card}" 
                Padding="12" 
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" 
                           Text="Сканированные коды:" 
                           Style="{StaticResource BodyTextSmall}" 
                           Foreground="Gray"
                           Margin="0,0,0,8"/>
                <ListBox x:Name="lbCodes" 
                         Grid.Row="1"
                         DisplayMemberPath="."
                         BorderThickness="0"
                         Background="Transparent"/>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="8">
            <Button x:Name="btnUndo" 
                    Content="Отменить последнее" 
                    Style="{StaticResource OutlineButton}"
                    Click="BtnUndo_Click"
                    IsEnabled="False"/>
            <Button Content="ОК" 
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>