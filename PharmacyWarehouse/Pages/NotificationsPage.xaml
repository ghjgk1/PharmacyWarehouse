<Page x:Class="PharmacyWarehouse.Pages.NotificationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Уведомления">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <Border Style="{StaticResource Card}">
                <TextBlock Text="🔔 Уведомления" Style="{StaticResource H1}"/>
            </Border>

            <!-- Низкий остаток -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                    Background="#FFF8E1" BorderBrush="#FF9800" BorderThickness="0">
                <Grid>
                    <Border Width="5" HorizontalAlignment="Left" Background="#FF9800" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="16,0,0,0">
                        <TextBlock Text="Низкий остаток" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                        <DataGrid x:Name="dgLowStock" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" MaxHeight="220" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="150"/>
                                <DataGridTextColumn Header="Текущий остаток" Binding="{Binding CurrentStock}" Width="120"/>
                                <DataGridTemplateColumn Header="Действие" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="📥 Приход"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="6,2"
                                                    Click="CreateReceipt_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Истекает срок -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                    Background="#FBE9E7" BorderBrush="#FF5722" BorderThickness="0">
                <Grid>
                    <Border Width="5" HorizontalAlignment="Left" Background="#FF5722" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="16,0,0,0">
                        <TextBlock Text="Истекает срок годности (&lt; 30 дней)" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                        <DataGrid x:Name="dgExpiring" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" MaxHeight="220" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="150"/>
                                <DataGridTextColumn Header="Ближайшая дата истечения"
                                                    Binding="{Binding NearestExpirationDate, StringFormat='dd.MM.yyyy'}" Width="160"/>
                                <DataGridTemplateColumn Header="Действие" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="📤 Списать"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="6,2"
                                                    Click="WriteOff_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Просрочено -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                    Background="#FFEBEE" BorderBrush="#F44336" BorderThickness="0">
                <Grid>
                    <Border Width="5" HorizontalAlignment="Left" Background="#F44336" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="16,0,0,0">
                        <TextBlock Text="Просрочено" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                        <DataGrid x:Name="dgExpired" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" MaxHeight="220" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="150"/>
                                <DataGridTextColumn Header="Ближайшая дата истечения"
                                                    Binding="{Binding NearestExpirationDate, StringFormat='dd.MM.yyyy'}" Width="160"/>
                                <DataGridTemplateColumn Header="Действие" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="📤 Списать"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="6,2"
                                                    Click="WriteOff_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
