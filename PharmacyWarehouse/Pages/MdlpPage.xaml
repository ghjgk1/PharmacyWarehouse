<Page x:Class="PharmacyWarehouse.Pages.MdlpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PharmacyWarehouse.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="МДЛП">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="20,20,20,10">
            <TextBlock Text="📡 МДЛП - Журнал операций и настройки" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Управление маркировкой лекарственных препаратов" 
                       FontSize="14" Foreground="Gray" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="20,0,20,20">
            <!-- Вкладка 1: Журнал отправок -->
            <TabItem Header="📋 Журнал отправок">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgDocuments" Grid.Row="1" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="DgDocuments_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата отправки" Binding="{Binding SentAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="*"/>
                            <DataGridTextColumn Header="Тип операции" Binding="{Binding OperationTypeText}" Width="*"/>
                            <DataGridTextColumn Header="Номер документа" Binding="{Binding Document.Number}" Width="*"/>
                            <DataGridTextColumn Header="Ticket" Binding="{Binding Ticket}" Width="*"/>
                            <DataGridTextColumn Header="Схема" Binding="{Binding SchemaVersion}" Width="*"/>
                            <DataGridTextColumn Header="Попыток" Binding="{Binding RetryCount}" Width="*"/>
                            <DataGridTemplateColumn Header="Статус" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusText}" 
                                                   Foreground="{Binding StatusColor}"
                                                   VerticalAlignment="Center"
                                                   Margin="10 0"
                                                   FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID МДЛП" Binding="{Binding MdlpDocumentId}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button x:Name="btnRetry" Content="🔄 Повторить отправку" 
                                Click="BtnRetry_Click" 
                                Padding="20,10" Margin="5"/>
                        <Button x:Name="btnViewXml" Content="📄 Просмотреть XML" 
                                Click="BtnViewXml_Click" 
                                Padding="20,10" Margin="5"/>
                        <Button x:Name="btnRefresh" Content="🔄 Обновить" 
                            Click="BtnRefresh_Click" 
                            Padding="20,10" Margin="5"/>
                    </StackPanel>
                    
                    <!-- История статусов -->
                    <Border Grid.Row="3" Margin="0,10,0,0" Padding="10" 
                            Background="{StaticResource BackgroundLightBrush}" 
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="📜 История статусов" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                            <DataGrid x:Name="dgHistory" Grid.Row="1" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding ChangedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="*"/>
                                    <DataGridTemplateColumn Header="Статус" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusText}" 
                                                           Foreground="{Binding StatusColor}"
                                                           VerticalAlignment="Center"
                                                           Margin="10 0"
                                                           FontWeight="SemiBold"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="2*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Вкладка 2: Коды маркировки -->
            <TabItem Header="🏷️ Коды маркировки">
                <DataGrid x:Name="dgSgtins" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SGTIN" Binding="{Binding Sgtin}" Width="*"/>
                        <DataGridTextColumn Header="Партия" Binding="{Binding Batch.Series}" Width="*"/>
                        <DataGridTextColumn Header="Товар" Binding="{Binding Batch.Product.Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Статус" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusText}" 
                                               Foreground="{Binding StatusColor}"
                                               VerticalAlignment="Center"
                                               Margin="10 0"
                                               FontWeight="SemiBold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            
            <!-- Вкладка 3: Настройки -->
            <TabItem Header="⚙️ Настройки">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Общие настройки" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <CheckBox x:Name="chkUseMock" Content="Режим эмуляции (без реального подключения)" 
                                  Margin="0,0,0,15" FontSize="14"/>
                        
                        <TextBlock Text="URL API МДЛП" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtApiUrl" Margin="0,0,0,15" Padding="10"/>
                        
                        <TextBlock Text="ИНН организации" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtOrgInn" Margin="0,0,0,15" Padding="10"/>
                        
                        <TextBlock Text="Название организации" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtOrgName" Margin="0,0,0,15" Padding="10"/>
                        
                        <TextBlock Text="Client ID" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtClientId" Margin="0,0,0,15" Padding="10"/>
                        
                        <TextBlock Text="Subject ID*" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtSubjectId" Margin="0,0,0,15" Padding="10" MaxLength="36"/>
                        
                        <TextBlock x:Name="txtDelayLabel" Text="Задержка эмуляции (сек): 5" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Slider x:Name="sldDelay" Minimum="0" Maximum="60" Value="5" 
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                Margin="0,0,0,15"/>
                        
                        <TextBlock x:Name="txtErrorRateLabel" Text="Процент случайных ошибок: 10%" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Slider x:Name="sldErrorRate" Minimum="0" Maximum="100" Value="10" 
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Максимум повторных попыток" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMaxRetries" Margin="0,0,0,20" Padding="10"/>
                        
                        <Button x:Name="btnSaveSettings" Content="💾 Сохранить настройки" 
                                Click="BtnSaveSettings_Click"
                                Padding="30,15" 
                                HorizontalAlignment="Left"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
