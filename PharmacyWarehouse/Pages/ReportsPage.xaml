<Page x:Class="PharmacyWarehouse.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Отчёты">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <Border Style="{StaticResource Card}">
                <TextBlock Text="📈 Отчёты" Style="{StaticResource H1}"/>
            </Border>

            <TabControl Margin="0,16,0,0">
                <!-- Остатки на дату -->
                <TabItem Header="Остатки на дату">
                    <StackPanel Margin="8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Дата:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker x:Name="dpStockDate" Width="150"/>
                            <Button Content="Сформировать" Style="{StaticResource PrimaryButton}"
                                    Margin="12,0,0,0" Click="GenerateStock_Click"/>
                            <Button x:Name="btnExportStock" Content="Экспорт в Excel"
                                    Style="{StaticResource SuccessButton}" Margin="12,0,0,0"
                                    IsEnabled="False" Click="ExportStock_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="dgStock" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="120"/>
                                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="120"/>
                                <DataGridTextColumn Header="Серия" Binding="{Binding Series}" Width="80"/>
                                <DataGridTextColumn Header="Срок годности" Binding="{Binding ExpirationDate, StringFormat='dd.MM.yyyy'}" Width="100"/>
                                <DataGridTextColumn Header="Остаток" Binding="{Binding Quantity}" Width="70"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding SellingPrice, StringFormat=N2}" Width="80"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalValue, StringFormat=N2}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>

                <!-- Движение товаров -->
                <TabItem Header="Движение товаров">
                    <StackPanel Margin="8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker x:Name="dpMovementFrom" Width="130"/>
                            <TextBlock Text="По:" VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <DatePicker x:Name="dpMovementTo" Width="130"/>
                            <Button Content="Сформировать" Style="{StaticResource PrimaryButton}"
                                    Margin="12,0,0,0" Click="GenerateMovement_Click"/>
                            <Button x:Name="btnExportMovement" Content="Экспорт в Excel"
                                    Style="{StaticResource SuccessButton}" Margin="12,0,0,0"
                                    IsEnabled="False" Click="ExportMovement_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="dgMovement" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Начальный остаток" Binding="{Binding OpeningBalance}" Width="110"/>
                                <DataGridTextColumn Header="Приход" Binding="{Binding IncomingQty}" Width="70"/>
                                <DataGridTextColumn Header="Расход" Binding="{Binding OutgoingQty}" Width="70"/>
                                <DataGridTextColumn Header="Списание" Binding="{Binding WriteOffQty}" Width="80"/>
                                <DataGridTextColumn Header="Конечный остаток" Binding="{Binding ClosingBalance}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>

                <!-- Анализ продаж -->
                <TabItem Header="Анализ продаж">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker x:Name="dpSalesFrom" Width="130"/>
                            <TextBlock Text="По:" VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <DatePicker x:Name="dpSalesTo" Width="130"/>
                            <TextBlock Text="Топ:" VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <ComboBox x:Name="cmbTopN" Width="80" SelectedIndex="1">
                                <ComboBoxItem Content="5" Tag="5"/>
                                <ComboBoxItem Content="10" Tag="10"/>
                                <ComboBoxItem Content="20" Tag="20"/>
                                <ComboBoxItem Content="Все" Tag="0"/>
                            </ComboBox>
                            <Button Content="Сформировать" Style="{StaticResource PrimaryButton}"
                                    Margin="12,0,0,0" Click="GenerateSales_Click"/>
                            <Button x:Name="btnExportSales" Content="Экспорт в Excel"
                                    Style="{StaticResource SuccessButton}" Margin="12,0,0,0"
                                    IsEnabled="False" Click="ExportSales_Click"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="dgSales" Grid.Column="0" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False" Margin="0,0,8,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Место" Binding="{Binding Rank}" Width="50"/>
                                    <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Продано (шт.)" Binding="{Binding TotalQuantitySold}" Width="90"/>
                                    <DataGridTextColumn Header="Выручка (руб.)" Binding="{Binding TotalRevenue, StringFormat=N2}" Width="100"/>
                                    <DataGridTextColumn Header="Средняя цена" Binding="{Binding AveragePricePerUnit, StringFormat=N2}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Grid.Column="1" Style="{StaticResource InfoBox}">
                                <StackPanel>
                                    <TextBlock Text="Гистограмма (топ-10)" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" Height="300">
                                        <ItemsControl x:Name="chartSales">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="4,0" VerticalAlignment="Bottom" Width="40">
                                                        <Rectangle Fill="{StaticResource PrimaryBrush}"
                                                                   Height="{Binding BarHeight}" VerticalAlignment="Bottom"/>
                                                        <TextBlock Text="{Binding Label}" FontSize="9"
                                                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Отчёт инвентаризации -->
                <TabItem Header="Отчёт инвентаризации">
                    <StackPanel Margin="8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Инвентаризация:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="cmbInventory" Width="280"
                                      DisplayMemberPath="DisplayText"/>
                            <Button Content="Сформировать" Style="{StaticResource PrimaryButton}"
                                    Margin="12,0,0,0" Click="GenerateInventory_Click"/>
                            <Button x:Name="btnExportInventory" Content="Экспорт в Excel"
                                    Style="{StaticResource SuccessButton}" Margin="12,0,0,0"
                                    IsEnabled="False" Click="ExportInventory_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="dgInventory" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Серия" Binding="{Binding Series}" Width="80"/>
                                <DataGridTextColumn Header="Срок годности" Binding="{Binding ExpirationDate, StringFormat='dd.MM.yyyy'}" Width="100"/>
                                <DataGridTextColumn Header="Учётный остаток" Binding="{Binding AccountedQuantity}" Width="110"/>
                                <DataGridTextColumn Header="Фактический остаток" Binding="{Binding ActualQuantity}" Width="120"/>
                                <DataGridTextColumn Header="Расхождение" Binding="{Binding Difference}" Width="90"/>
                                <DataGridTextColumn Header="Статус расхождения" Binding="{Binding DifferenceStatus}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </StackPanel>
    </ScrollViewer>
</Page>
